{
  "skillListingBudgetFraction": 0.02,
  "env": {
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(sudo *)",
      "Bash(paru *)",
      "Bash(snapper *)",
      "Bash(grim *)",
      "Bash(pkill *)",
      "Bash(kitten *)",
      "Bash(playwright-cli *)",
      "Bash(hyprctl *)",
      "Bash(makoctl *)",
      "Bash(chmod * ~/.config/**)",
      "Bash(chmod * ~/.local/**)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus[1m]",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/hmail-hook.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.local/bin/claude-inhibit-start.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/claude-inhibit-stop.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/claude-edit-snap.sh",
            "timeout": 30,
            "statusMessage": "Snapshot Btrfs antes de editar config critica...",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/disable-claude-mcps.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.local/bin/cc-statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "learning-mode@antolin-plugins": true
  },
  "extraKnownMarketplaces": {
    "claude-code-workflows": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      }
    },
    "antolin-plugins": {
      "source": {
        "source": "github",
        "repo": "TonioAmc/claude-learning-mode"
      }
    }
  },
  "language": "espanol",
  "effortLevel": "xhigh",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "normal",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}
